@inject NavigationManager Navigation
@using CryptoSim.Blazor.Services
@rendermode InteractiveServer
@implements IDisposable

<header class="trading-header shadow-sm">
    <div class="header-container">
        <div class="brand-section">
            <NavLink class="header-logo" href="" Match="NavLinkMatch.All">
                <span class="logo-icon">₿</span>
                <span class="logo-text">CryptoSim</span>
            </NavLink>
        </div>
        <div class="user-section">
            <div class="balance-display">
                <span class="balance-amount">@AuthState.Balance.ToString("N2")</span>
                <span class="balance-currency">$</span>
            </div>
            <div class="action-icons">
                <button class="icon-btn-trading" @onclick="HandleToggle" title="Changer le thème">
                    @if (_localDark)
                    {
                        <i class="bi bi-moon-stars"></i>
                    }
                    else
                    {
                        <i class="bi bi-sun"></i>
                    }
                </button>
                <button class="icon-btn-trading" title="Notifications">
                    <i class="bi bi-bell-fill"></i>
                </button>
                <div class="avatar-wrapper">
                    @* CORRECTION ICI :
                       1. La classe est "user-avatar-initial" (minuscule).
                       2. Ajout de tabindex="0" pour rendre la div focusable.
                       3. Ajout de @onblur pour fermer le menu quand on clique ailleurs. *@
                    <div class="user-avatar-initial"
                         @onclick="ToggleMenu"
                         @onblur="CloseMenu"
                         tabindex="0"
                         title="Menu utilisateur">
                        <span>@_Initial</span>
                    </div>

           
                    @if (isMenuOpen)
                    {
                        <div class="user-dropdown show animate-fade-in">
                            <div class="dropdown-user-info">
                                <div class= "dropdown-username" > @AuthState.Username </div>
                                <div class= "badge-status" > @AuthState.Role </div>
                            </div>
                            <hr class="dropdown-divider" />
                            <NavLink href="profil" class="dropdown-link" @onclick="CloseMenu">
                                <i class="bi bi-person-circle"></i> Modifier mon Profil
                            </NavLink>
                            <NavLink href="transfert" class="dropdown-link" @onclick="CloseMenu">
                                <i class="bi bi-box-arrow-in-down"></i> Dépôt/Retrait
                            </NavLink>
                            <button class="dropdown-link logout-text" @onclick="Logout">
                                <i class="bi bi-box-arrow-right"></i> Déconnexion
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</header>

