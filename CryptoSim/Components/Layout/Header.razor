@* On injecte le NavigationManager au cas où tu en as besoin pour la déconnexion *@
@inject NavigationManager Navigation
@rendermode InteractiveServer


<header class="trading-header shadow-sm">
    <div class="header-container">
        <div class="brand-section">
            <NavLink class="header-logo" href="" Match="NavLinkMatch.All">
                <span class="logo-icon">₿</span>
                <span class="logo-text">CryptoSim</span>
            </NavLink>
        </div>

        <div class="user-section">
            <div class="balance-display">
                <span class="balance-amount">10,000.00</span>
                <span class="balance-currency">VF</span>
            </div>

            <div class="action-icons">
                <button class="icon-btn-trading" title="Dépôt/Retrait">
                    <i class="bi bi-lightning-fill"></i>
                </button>
                <button class="icon-btn-trading" title="Notifications">
                    <i class="bi bi-bell-fill"></i>
                </button>

                @* --- BLOC AVATAR MODIFIÉ --- *@
                <div class="avatar-wrapper">
                    <div class="user-avatar-initial" @onclick="ToggleMenu">
                        <span>B</span>
                    </div>

                    @if (isMenuOpen)
                    {
                        <div class="user-dropdown animate-fade-in">
                            <div class="dropdown-user-info">
                                <strong>Baptiste</strong>
                                <span class="badge-status"> - Premium</span>
                            </div>

                            <hr class="dropdown-divider" />

                            <NavLink href="profil" class="dropdown-link" @onclick="CloseMenu">
                                <i class="bi bi-person-circle"></i> Modifier mon Profil
                            </NavLink>

                            <button class="dropdown-link logout-text" @onclick="Logout">
                                <i class="bi bi-box-arrow-right"></i> Déconnexion
                            </button>
                        </div>
                    }
                </div>
                @* --------------------------- *@
            </div>
        </div>
    </div>
</header>

@code {
    // Variable pour suivre l'état du menu (ouvert/fermé)
    private bool isMenuOpen = false;

    // Méthode pour inverser l'état
    private void ToggleMenu() => isMenuOpen = !isMenuOpen;

    // Méthode pour fermer le menu quand on clique sur un lien
    private void CloseMenu() => isMenuOpen = false;

    private void Logout()
    {
        // Logique de déconnexion à ajouter ici plus tard
        isMenuOpen = false;
        Navigation.NavigateTo("/login");
    }
}