@rendermode InteractiveServer
@page "/login"
@using CryptoSim.Blazor.Components.Layout
@using CryptoSim.Blazor.Services
@layout EmptyLayout
@inject NavigationManager Navigation
@inject AuthService AuthService

<div class="login-page">
    <div class="login-card animate-fade-in">
        <div class="login-header">
            <span class="logo-icon">₿</span>
            <h1 class="logo-text">CryptoSim</h1>
            <p class="subtitle">Connectez-vous pour trader</p>
        </div>
        <form class="login-form" @onsubmit="HandleLogin" @onsubmit:preventDefault>
            <div class="form-group">
                <label>Email ou Utilisateur</label>
                <div class="input-wrapper">
                    <i class="bi bi-person"></i>
                    <input type="text" @bind="_username" placeholder="yann@cryptosim.com" />
                </div>
            </div>
            <div class="form-group">
                <label>Mot de passe</label>
                <div class="input-wrapper">
                    <i class="bi bi-lock"></i>
                    <input type="password" @bind="_password" placeholder="••••••••" />
                </div>
            </div>
            @if (!string.IsNullOrEmpty(_error))
            {
                <p class="text-danger">@_error</p>
            }
            <button type="submit" class="btn-login-neon" disabled="@_isLoading">
                @(_isLoading ? "Connexion..." : "SE CONNECTER")
            </button>
        </form>
        <div class="login-footer">
            <a href="forgot-password">Mot de passe oublié ?</a>
            <span>Pas de compte ? <a href="register" class="text-neon">S'inscrire</a></span>
        </div>
    </div>
</div>

