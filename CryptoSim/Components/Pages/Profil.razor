@rendermode InteractiveServer
@page "/Profil"
@using CryptoSim.Blazor.Services

<PageTitle>Profil</PageTitle>

<div class="profile-container animate-fade-in">
    @* --- HEADER --- *@
    <div class="header-tabs">
        <h1 class="main-page-title text-gold">MON PROFIL UTILISATEUR</h1>
    </div>
    <div class="header-separator-bar"></div>

    <div class="profile-grid">
        @* --- COLONNE GAUCHE (Toujours visible) --- *@
        <div class="standard-card">
            <h3 class="card-subtitle">INFORMATIONS PERSONNELLES</h3>

            <div class="avatar-section">
                <div class="avatar-circle">YH</div>
            </div>

            <div class="info-list">
                <div class="detail-row"><label>NOM D'UTILISATEUR</label><span>@AuthState.Username</span></div>
                <div class="detail-row"><label>EMAIL</label><span>@AuthState.Email</span></div>
                <div class="detail-row"><label>RÔLE</label><span>@AuthState.Role</span></div>
                <div class="detail-row"><label>DATE D'INSCRIPTION</label><span>@AuthState.CreatedAt.ToString("dd/MM/yyyy")</span></div>
            </div>

            <div class="action-buttons">
                <button class="btn-glass text-gold" @onclick="OpenEditPassword">
                    MODIFIER LE MOT DE PASSE
                </button>
                <button class="btn-glass text-gold" @onclick="OpenEditUsername">MODIFIER LE NOM D'UTILISATEUR</button>
                <button class="btn-glass secondary text-grise">ACTIVER L'AUTH. DOUBLE FACTEUR</button>
            </div>
        </div>

        @* --- COLONNE DROITE (Dynamique) --- *@
        <div class="standard-card relative-card">
            @if (!isEditingPassword && !isEditingUsername)
            {
                <h3 class="card-subtitle">RÉSUMÉ ET PERFORMANCE</h3>
                <div class="gauge-container animate-fade-in">
                    @* On injecte le dégradé dynamiquement via l'attribut style *@
                    <div class="circular-gauge"
                         style="background: conic-gradient(@(IsPositive ? "var(--green)" : "var(--red)") 0% @(Math.Abs(PerformancePercentage).ToString("0.0", System.Globalization.CultureInfo.InvariantCulture))%, #232834 0% 100%);
                        box-shadow: 0 0 30px @(IsPositive ? "rgba(0, 255, 136, 0.2)" : "rgba(255, 77, 77, 0.2)");">
        
                        <div class="gauge-inner">
                            <span class="gauge-label">PERFORMANCE GLOBALE</span>
                            <span class="gauge-value" style="color: @(IsPositive ? "var(--green)" : "var(--red)")">
                                @(PerformancePercentage >= 0 ? "+" : "")@PerformancePercentage.ToString("N1")%
                            </span>
                        </div>
                    </div>
                </div>
                <div class="stats-footer animate-fade-in">
                    <div class="mini-box text-gold">
                        <label>FOND INITIAL</label>
                        <div class="stat-content">@FondInitial.ToString("N2") $ <i class="bi bi-safe2-fill"></i></div>
                    </div>
                    <div class="mini-box text-gold">
                        <label>FOND ACTUEL</label>
                        <div class="stat-content">@AuthState.Balance.ToString("N2") $ <i class="bi bi-wallet2"></i></div>
                    </div>

                    @* Utilisation des propriétés calculées dans le @code *@
                    <div class="mini-box @StatusClass">
                        <label>@StatusLabel</label>
                        <div class="stat-content">
                            @Difference.ToString("N2") $ <i class="bi @IconClass"></i>
                        </div>
                    </div>
                </div>
            }
            else if (isEditingPassword)
            {

                <button class="close-btn" @onclick="() => isEditingPassword = false">
                    <i class="bi bi-x-lg"></i>
                </button>

                <h3 class="card-subtitle">MODIFIER LE MOT DE PASSE</h3>

                <div class="form-container animate-fade-in">
                    @* Ligne 1 : Mot de passe actuel *@
                    <div class="form-row">
                        <div class="form-group">
                            <label><i class="bi bi-shield-lock"></i> MOT DE PASSE ACTUEL</label>
                            <input type="password" class="form-input" @bind="_currentPassword" placeholder="Saisissez votre mot de passe actuel" />
                        </div>
                    </div>

                    @* Ligne 2 : Nouveaux mots de passe côte à côte *@
                    <div class="form-row password-grid">
                        <div class="form-group">
                            <label><i class="bi bi-key"></i> NOUVEAU MOT DE PASSE</label>
                            <input type="password" class="form-input" @bind="_newPassword" placeholder="Nouveau mot de passe" />
                        </div>
                        <div class="form-group">
                            <label><i class="bi bi-check2-circle"></i> CONFIRMATION</label>
                            <input type="password" class="form-input" @bind="_confirmPassword" placeholder="Confirmez le mot de passe" />
                        </div>
                    </div>

                    @* Ligne 3 : Actions *@
                    <div class="action-buttons-container">
                        <button class="btn-glass text-gold" @onclick="HandleSave">ENREGISTRER LES MODIFICATIONS</button>
                        <button class="btn-cancel" @onclick="() => isEditingPassword = false">ANNULER</button>
                    </div>
                </div>
            }
            else if (isEditingUsername)
            {
                @* VUE 3 : FORMULAIRE PSEUDO *@
                <button class="close-btn" @onclick="CloseAllEdits"><i class="bi bi-x-lg"></i></button>
                <h3 class="card-subtitle">MODIFIER LE NOM D'UTILISATEUR</h3>
                <div class="form-container animate-fade-in">
                    <div class="form-group">
                        <label><i class="bi bi-person-badge"></i> NOUVEAU NOM D'UTILISATEUR</label>
                        <input type="text" class="form-input" @bind="_newUsername" placeholder="Yann_Helouri" />
                    </div>
                    <div class="form-group">
                        <label><i class="bi bi-shield-lock"></i> CONFIRMER AVEC VOTRE MOT DE PASSE</label>
                        <input type="password" class="form-input" @bind="_confirmPasswordForUsername" placeholder="Entrez votre mot de passe pour valider" />
                    </div>
                    <div class="action-buttons-container">
                        <button class="btn-glass text-gold" @onclick="HandleSave">METTRE À JOUR LE NOM D'UTILISATEUR</button>
                        <button class="btn-cancel" @onclick="CloseAllEdits">ANNULER</button>
                    </div>
                </div>
            }

        </div>
    </div>
</div>

