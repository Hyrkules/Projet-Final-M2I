@page "/trade"
@rendermode InteractiveServer
@using CryptoSim.Blazor.Services
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject HttpClient Http

<PageTitle>Trade - @selectedSymbol</PageTitle>

<div class="profile-container animate-fade-in">
    <div class="wallet-page-header">
        <h1 class="main-page-title text-gold">ACHAT / VENTE DE CRYPTO</h1>
    </div>
</div>

<div class="header-separator-bar"></div>

<div class="trade-main-grid">
    @* --- COLONNE GAUCHE : GRAPHIQUE --- *@
    <div class="standard-card chart-container-pro grid-col-span-2">
        <h3 class="card-subtitle">COURS EN TEMPS RÉEL</h3>
        <div class="chart-controls">
            <div class="asset-info">
                <div class="input-with-icon">
                    <img src="@GetSelectedCryptoImage()" class="crypto-select-icon" />
                    <select class="form-input custom-dashboard-select" @onchange="OnCryptoChanged">
                        <option value="BTCUSDT">BabyBitcoin (BBTC)</option>
                        <option value="SOLUSDT">PikaCoin (PIKA)</option>
                        <option value="ETHUSDT">MoonCoin (MOON)</option>
                    </select>
                </div>
                <div class="price-badge-group">
                    <span id="live-price-val" class="live-price">--.--€</span>
                    <span id="live-price-change" class="price-change positive">0.00%</span>
                </div>
                <div class="market-stats-mini">
                    <div class="stat">
                        <span class="label">VOL 24H</span>
                        <span id="live-vol-24h" class="value">--.--</span>
                    </div>
                    <div class="stat">
                        <span class="label">HIGH</span>
                        <span id="live-high" class="value green">--.--</span>
                    </div>
                    <div class="stat">
                        <span class="label">LOW</span>
                        <span id="live-low" class="value red">--.--</span>
                    </div>
                </div>
            </div>
            @* ... Stats mini identiques ... *@
        </div>
        <div id="cryptoChart" style="width: 100%; height: 350px;"></div>
    </div>

    @* --- COLONNE DROITE : ORDERBOOK & TERMINAL --- *@
    <div class="trade-right-panel">
        @* --- CARNET D'ORDRES (JS gère le remplissage) --- *@
        <div class="standard-card order-book-card">
            <h3 class="card-subtitle">CARNET D'ORDRES</h3>
            <div class="order-book-container">
                <div class="ob-spread"><span class="red">VENTES</span></div>
                <div class="asks"></div>
                <div class="ob-spread"><span class="green">ACHATS</span></div>
                <div class="bids"></div>
            </div>
        </div>

        @* --- TERMINAL D'ACHAT/VENTE FONCTIONNEL --- *@
        <div class="standard-card trade-terminal">
            <div class="trade-tabs">
                <button class="tab-btn @(TradeMode == "BUY" ? "active-buy" : "")" @onclick='() => SwitchMode("BUY")'>ACHAT</button>
                <button class="tab-btn @(TradeMode == "SELL" ? "active-sell" : "")" @onclick='() => SwitchMode("SELL")'>VENTE</button>
            </div>

            <div class="terminal-body">
                <div class="balance-info">
                    <span>Disponible:</span>
                    <span class="text-gold">
                        @if (TradeMode == "BUY")
                        {
                            @($"{FakeEurBalance.ToString("N2")} €")
                        }
                        else
                        {

                            @($"{FakeCryptoBalance.ToString("N4")} {GetBaseAsset()}")
                        }
                    </span>
                </div>

                <div class="trade-input-group">
                    <label>Quantité à @(TradeMode == "BUY" ? "dépenser" : "vendre")</label>
                    <div class="input-wrapper">
                        <input type="number" @bind="TradeAmount" @bind:event="oninput" placeholder="0.00" step="0.01" />
                        <span class="unit">@(TradeMode == "BUY" ? "€" : GetBaseAsset())</span>
                    </div>
                </div>

                <div class="percent-grid">
                    <button @onclick="() => SetAmount(25)">25%</button>
                    <button @onclick="() => SetAmount(50)">50%</button>
                    <button @onclick="() => SetAmount(75)">75%</button>
                    <button @onclick="() => SetAmount(100)">MAX</button>
                </div>

                <div class="order-summary">
                    <div class="sum-row">
                        <span>Estimation reçue:</span>
                        <span class="text-white">@EstimatedTotal.ToString(TradeMode == "BUY" ? "N6" : "N2") @(TradeMode == "BUY" ? GetBaseAsset() : "€")</span>
                    </div>
                    <div class="sum-row">
                        <span>Frais (0.1%):</span>
                        <span>@((TradeAmount * 0.001).ToString("N4")) @(TradeMode == "BUY" ? "€" : GetBaseAsset())</span>
                    </div>
                </div>

                <button class="main-trade-btn @(TradeMode == "BUY" ? "btn-buy" : "btn-sell")"
                        @onclick="ExecuteTrade"
                        disabled="@(TradeAmount <= 0)">
                    @(TradeMode == "BUY" ? "CONFIRMER L'ACHAT" : "CONFIRMER LA VENTE")
                </button>
            </div>
        </div>
    </div>
</div>

@code {

    
}

