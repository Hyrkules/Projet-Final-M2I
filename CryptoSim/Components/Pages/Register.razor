@rendermode InteractiveServer
@page "/register"
@using CryptoSim.Blazor.Components.Layout
@using CryptoSim.Blazor.Services
@layout EmptyLayout
@inject NavigationManager Navigation
@inject AuthService AuthService

<div class="login-page">
    <div class="login-card animate-fade-in">
        <div class="login-header">
            <span class="logo-icon">₿</span>
            <h1 class="logo-text">CryptoSim</h1>
            <p class="subtitle">Créez votre compte de trading</p>
        </div>
        <form class="login-form" @onsubmit="HandleRegister" @onsubmit:preventDefault>
            <div class="form-group">
                <label>Nom d'utilisateur</label>
                <div class="input-wrapper">
                    <i class="bi bi-person"></i>
                    <input type="text" @bind="_username" placeholder="TradersDuDimanche" required />
                </div>
            </div>
            <div class="form-group">
                <label>Email</label>
                <div class="input-wrapper">
                    <i class="bi bi-envelope"></i>
                    <input type="email" @bind="_email" placeholder="yann@cryptosim.com" required />
                </div>
            </div>
            <div class="form-group">
                <label>Mot de passe</label>
                <div class="input-wrapper">
                    <i class="bi bi-lock"></i>
                    <input type="password" @bind="_password" placeholder="••••••••" required />
                </div>
            </div>
            <div class="form-group">
                <label>Confirmer le mot de passe</label>
                <div class="input-wrapper">
                    <i class="bi bi-shield-lock"></i>
                    <input type="password" @bind="_confirmPassword" placeholder="••••••••" required />
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <p class="text-danger">@_error</p>
            }

            <button type="submit" class="btn-login-neon" disabled="@_isLoading">
                @(_isLoading ? "Création en cours..." : "CRÉER MON COMPTE")
            </button>
        </form>
        <div class="login-footer">
            <span>Déjà un compte ? <NavLink href="login" class="text-neon">Se connecter</NavLink></span>
        </div>
    </div>
</div>

