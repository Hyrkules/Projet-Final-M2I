@rendermode InteractiveServer
@page "/forgot-password"
@using CryptoSim.Blazor.Components.Layout
@layout EmptyLayout
@inject NavigationManager Navigation

<div class="login-page">
    <div class="login-card animate-fade-in">
        <div class="login-header">
            <span class="logo-icon">₿</span>
            <h1 class="logo-text">CryptoSim</h1>
            <p class="subtitle">Récupération de compte</p>
            <p class="info-text">Saisissez votre email pour recevoir un lien de réinitialisation.</p>
        </div>

        @if (!isSent)
        {
            <form class="login-form" @onsubmit="HandleReset" @onsubmit:preventDefault>
                <div class="form-group">
                    <label>Email de récupération</label>
                    <div class="input-wrapper">
                        <i class="bi bi-envelope"></i>
                        <input type="email" placeholder="yann@cryptosim.com" required @bind="email" />
                    </div>
                </div>

                <button type="submit" class="btn-login-neon">
                    ENVOYER LE LIEN
                </button>
            </form>
        }
        else
        {
            <div class="success-message animate-fade-in">
                <i class="bi bi-check2-circle"></i>
                <p>Si cet email existe, un lien a été envoyé.</p>
            </div>
        }

        <div class="login-footer">
            <NavLink href="login">Retour à la connexion</NavLink>
        </div>
    </div>
</div>

