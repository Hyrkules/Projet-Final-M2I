@rendermode InteractiveServer
@page "/"
@using CryptoSim.Blazor.Services
@inject NavigationManager Navigation
@inject HttpClient Http

<PageTitle>Home</PageTitle>

<div class="profile-container animate-fade-in">
    <div class="balance-badge">
        <span class="label">VALEUR TOTALE</span>
        <span class="value">@AuthState.Balance.ToString("N2") $</span>
    </div>
</div>
    <div class="header-separator-bar"></div>
    <div class="row g-4 mt-4">
        <div class="col-md-4">
            <div class="card bg-dark-card border-secondary p-3 text-center">
                <h5 class="text-muted">Marché Actif</h5>
                <h2 class="text-white">
                    @(_cryptoCount.HasValue ? $"{_cryptoCount} Actifs" : "Chargement...")
                </h2>
            </div>
    </div>
</div>
<div class="row g-4 mt-4">
    <div class="col-md-4">
        <div class="card bg-dark-card border-secondary p-3 text-center">
            <h5 class="text-muted">Marché Actif</h5>
            <h2 class="text-white">
                @(_cryptoCount.HasValue ? $"{_cryptoCount} Actifs" : "Chargement...")
            </h2>

        </div>
        <div class="col-md-4">
            <div class="card bg-dark-card border-secondary p-3 text-center">
                <h5 class="text-muted">Transactions totales</h5>
                <h2 class="text-white">
                    @(_transactionCount.HasValue ? _transactionCount.ToString() : "Chargement...")
                </h2>
            </div>
            <div class="standard-card stat-item">
                <i class="bi bi-cpu text-gold"></i>
                <div>
                    <span class="stat-label">ACTIFS DÉTENUS</span>
                    <span class="stat-value">12 Jetons</span>
                </div>
            </div>
        </div>
    </div>
</div>

