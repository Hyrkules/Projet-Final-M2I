@rendermode InteractiveServer
@page "/"
@using CryptoSim.Blazor.Services
@inject NavigationManager Navigation

<PageTitle>Home</PageTitle>

<h1>Fichier Home.razor (CryptoSim.Blazor/Components/Pages/Home.razor)</h1>
<p>État auth : @AuthState.IsAuthenticated</p>
<div class="text-center py-5">
    <h1 class="display-3 fw-bold text-white">Prêt à <span class="text-neon">Trader</span> ?</h1>
    <p class="lead text-secondary">La simulation de crypto-monnaie la plus rapide pour Yann et Helouri.</p>
    <div class="mt-4">
        <a href="trade" class="btn btn-neon btn-lg px-5 me-3">Commencer à trader</a>
        <a href="portfolio" class="btn btn-outline-light btn-lg px-5">Voir mon solde</a>
    </div>
</div>

<div class="row g-4 mt-4">
    <div class="col-md-4">
        <div class="card bg-dark-card border-secondary p-3 text-center">
            <h5 class="text-muted">Marché Actif</h5>
            <h2 class="text-white">12 Actifs</h2>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-dark-card border-secondary p-3 text-center">
            <h5 class="text-muted">Transactions totales</h5>
            <h2 class="text-white">1,248</h2>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-dark-card border-secondary p-3 text-center">
            <h5 class="text-muted">Utilisateurs en ligne</h5>
            <h2 class="text-neon">42</h2>
        </div>
    </div>
</div>

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender) // On ne vérifie qu'au tout premier chargement
        {
            if (!AuthState.IsAuthenticated)
            {
                Navigation.NavigateTo("/login");
            }
        }
    }
}